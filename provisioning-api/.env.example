# Railway
RAILWAY_API_TOKEN=your-railway-api-token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OLI Mattermost image (Docker Hub default below; override if you use GHCR, etc.)
OLI_MATTERMOST_IMAGE=docker.io/vosv/oli-mattermost:latest

# Railway: lite = one Mattermost + SQLite (default; works on free tier). full = Postgres + Mattermost (two services).
OLI_RAILWAY_STACK_MODE=lite

# Port
PORT=3002
