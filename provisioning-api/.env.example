# Railway
RAILWAY_API_TOKEN=your-railway-api-token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OLI OLI image (Docker Hub default below; override if you use GHCR, etc.)
OLI_MATTERMOST_IMAGE=docker.io/vosv/oli-mattermost:latest

# Railway: lite = one OLI + SQLite (default; works on free tier). full = Postgres + OLI (two services).
OLI_RAILWAY_STACK_MODE=lite

# Shared AI service (all orgs use the same instance)
OLI_AI_SERVICE_URL=https://oli-ai-service-production.up.railway.app
OLI_AI_SERVICE_SECRET=your-shared-secret
OLI_OPENAI_API_KEY=your-openai-api-key

# Port
PORT=3002
